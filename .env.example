# ══════════════════════════════════════════════════════════════════════════════
# QUANTITY MEASUREMENT APP - ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!
# ══════════════════════════════════════════════════════════════════════════════

# ── JWT Configuration (REQUIRED) ──────────────────────────────────────────────
# Generate a secure key with: openssl rand -base64 32
# Must be minimum 32 characters
JWT_KEY=QuantityMeasurementSuperSecretKey2024!!MustBe32Chars

JWT_ISSUER=QuantityMeasurementApi
JWT_AUDIENCE=QuantityMeasurementApp

# ── Google OAuth (OPTIONAL - for Google Sign-In) ──────────────────────────────
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=7784755581-3tgrcvebpnfimhmrjgulppk6biarm14n.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=*****

# ── Database Configuration ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qma_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis Configuration ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Frontend URL ───────────────────────────────────────────────────────────────
# Update this to your Angular frontend URL
FRONTEND_BASE_URL=https://quantitymeasurementapp-frontend-opsu.onrender.com

# ── Service URLs (Docker internal) ─────────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8080
QMA_SERVICE_URL=http://qma-service:8080

# ── Production Settings (Update for deployment) ───────────────────────────────
# ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=https://+:443;http://+:80
